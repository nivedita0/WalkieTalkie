# Copy to `backend/.env`.
# OpenRouter API:
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional but recommended for rankings/analytics:
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=WalkieTalkie-VA
FORCE_OLLAMA_FALLBACK=false

# OpenWeatherMap (https://openweathermap.org/api — free tier, 1000 calls/day):
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
SERPAPI_API_KEY=your_serpapi_key_here

# OpenRouter model IDs (small vs large + vision):
SMALL_LLM_MODEL=nvidia/nemotron-nano-9b-v2:free
LARGE_LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
VISION_LLM_MODEL=nvidia/nemotron-nano-9b-v2:free

# Embeddings:
# Option A (OpenRouter embeddings): set this model id and you don't need Ollama embeddings.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Option B (fallback via local Ollama):
OLLAMA_BASE_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_SMALL_LLM_MODEL=llama3.2:latest
OLLAMA_LARGE_LLM_MODEL=qwen2.5-coder:14b
OLLAMA_VISION_LLM_MODEL=llama3.2-vision:latest

REFLECTION_ENABLED=true
HERO_CHAIN_PREFETCH=true
